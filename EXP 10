#1. Display the names of employees from department number 10 with salary greater than that of any employee working in other departments 
SELECT ENAME
FROM EMPLOYEE
WHERE DEPTNO = 10
AND SAL > ANY (
    SELECT SAL FROM EMPLOYEE WHERE DEPTNO <> 10
);

